# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the Vite client.
# Keep this value in .env/.env.local only; do not commit real keys.
VITE_GEMINI_API_KEY=

# GEMINI_API_KEY: Optional server/runtime alias for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps Platform services.
# Users configure this via the Secrets panel in the AI Studio UI.
GOOGLE_MAPS_PLATFORM_KEY=

# ── Google Cloud Healthcare API ──────────────────────────────────
# GCP_PROJECT_ID: ID del proyecto en Google Cloud
GCP_PROJECT_ID=salud-conecta-ia-497023
# GCP_LOCATION: Región del dataset Healthcare
GCP_LOCATION=us-central1
# GCP_DATASET_ID: Nombre del dataset Healthcare
GCP_DATASET_ID=saludconecta-dataset
# GCP_FHIR_STORE_ID: Nombre del FHIR Store
GCP_FHIR_STORE_ID=saludconecta-fhir
# GOOGLE_APPLICATION_CREDENTIALS: Ruta al JSON de la cuenta de servicio.
# Se auto-detecta en /config/ si no se especifica.
GOOGLE_APPLICATION_CREDENTIALS=

# ── Backend Server ───────────────────────────────────────────────
# SERVER_PORT: Puerto del servidor Express backend
SERVER_PORT=3001
